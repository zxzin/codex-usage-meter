{
  "name": "token-meter",
  "version": "0.1.8",
  "private": true,
  "type": "module",
  "bin": {
    "token-meter": "./scripts/launch.mjs",
    "codex-usage-meter": "./scripts/launch.mjs"
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 1420",
    "build": "tsc && vite build",
    "launch": "node scripts/launch.mjs",
    "install:claude": "node scripts/install-claude.mjs",
    "claude:install": "node scripts/install-claude.mjs",
    "preview": "vite preview --host 127.0.0.1 --port 1420",
    "tauri": "tauri",
    "tauri:dev": "tauri dev --features direct-download",
    "tauri:build": "tauri build --features direct-download",
    "tauri:build:mac": "tauri build --features direct-download --bundles app,dmg",
    "tauri:build:windows": "tauri build --features direct-download --bundles nsis,msi",
    "tauri:build:appstore": "node scripts/build-app-store.mjs"
  },
  "dependencies": {
    "@choochmeque/tauri-plugin-iap-api": "0.9.0",
    "@tauri-apps/api": "2.11.1",
    "@tauri-apps/plugin-opener": "2.5.4",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@tauri-apps/cli": "2.11.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "typescript": "^6.0.3",
    "vite": "^8.1.0"
  }
}
